{
  "name": "memcachify",
  "version": "1.1.0",
  "description": "Production-ready lightweight in-memory caching middleware for Node.js (Express + Fastify) & client side caching.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "lint": "eslint . --ext .ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "cachify",
    "cachely",
    "cache",
    "middleware",
    "express",
    "fastify",
    "in-memory",
    "ttl",
    "in-memory-cache"
  ],
  "author": "Darshan Battula",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.14.0",
    "express": "^4.18.2",
    "@types/supertest": "^2.0.14",
    "supertest": "^6.3.3",
    "eslint": "^8.57.0",
    "eslint-config-standard-with-typescript": "^29.0.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-promise": "^6.1.1",
    "tsup": "^6.7.0",
    "typescript": "^5.5.0",
    "vitest": "^1.5.2",
    "fastify": "^5.8.0"
  },
  "peerDependencies": {
    "express": "^4.17.0 || ^5.0.0",
    "fastify": "^4.0.0 || ^5.0.0"
  }
}
